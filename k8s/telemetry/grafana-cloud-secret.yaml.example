---
# Copy this file to grafana-cloud-secret.yaml, fill in your values, apply it, then
# delete the plaintext file. It is gitignored — never commit credentials.
#
# How to find these values in Grafana Cloud:
#   GC_OTLP_ENDPOINT:  Stack → OpenTelemetry (OTLP) → Endpoint
#                      (e.g. https://otlp-gateway-prod-us-central-0.grafana.net/otlp)
#   GC_OTLP_USERNAME:  Stack → OpenTelemetry (OTLP) → Instance ID  (numeric)
#   GC_PROM_ENDPOINT:  Stack → Prometheus → Remote Write URL
#                      (e.g. https://prometheus-us-central1.grafana.net/api/prom/push)
#   GC_PROM_USERNAME:  Stack → Prometheus → Instance ID  (numeric)
#   GC_LOKI_ENDPOINT:  Stack → Logs → URL  (e.g. https://logs-prod3.grafana.net)
#   GC_LOKI_USERNAME:  Stack → Logs → Instance ID  (numeric)
#   API_TOKEN:         Security → API Keys → New key (needs MetricsPublisher + LogsPublisher,
#                      or use an Editor-scoped token for simplicity)

apiVersion: v1
kind: Secret
metadata:
  name: grafana-cloud-credentials
  namespace: network-lab
type: Opaque
stringData:
  GC_OTLP_ENDPOINT: "https://otlp-gateway-prod-REGION.grafana.net/otlp"
  GC_OTLP_USERNAME: "1234567"
  GC_PROM_ENDPOINT: "https://prometheus-REGION.grafana.net/api/prom/push"
  GC_PROM_USERNAME: "1234567"
  GC_LOKI_ENDPOINT: "https://logs-prodN.grafana.net"
  GC_LOKI_USERNAME: "1234567"
  API_TOKEN:        "glc_eyJ..."
