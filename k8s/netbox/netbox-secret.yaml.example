---
# NetBox credentials Secret.
#
# USAGE:
#   cp k8s/netbox/netbox-secret.yaml.example k8s/netbox/netbox-secret.yaml
#   # Edit netbox-secret.yaml — fill in ALL placeholder values.
#   kubectl apply -f k8s/netbox/netbox-secret.yaml
#
# This file (netbox-secret.yaml) is listed in .gitignore — never commit it.
#
# KEY NOTES:
#   - superuser-password:  NetBox admin UI login password.
#   - superuser-api-token: Used by the populate-job and the netbox-sd service
#                          to authenticate REST API calls. Choose any 40-char
#                          hex string, e.g.:  openssl rand -hex 20
#   - secret-key:          Django session encryption key (50+ random chars).
#                          Generate with:  openssl rand -base64 40
#   - postgresql-password: Password for the embedded PostgreSQL database.

apiVersion: v1
kind: Secret
metadata:
  name: netbox-credentials
  namespace: network-tools
type: Opaque
stringData:
  superuser-password: "CHANGE_ME_admin_password"
  superuser-api-token: "CHANGE_ME_40_hex_chars_api_token_here_xx"
  secret-key: "CHANGE_ME_50plus_random_chars_for_django_session_secret_key"
  postgresql-password: "CHANGE_ME_postgres_password"
