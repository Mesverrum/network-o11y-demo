# Copy this file to terraform.tfvars (gitignored) and fill in your values.

# Your public IP in CIDR notation — find it with: curl -s ifconfig.me
allowed_ssh_cidr = "YOUR_PUBLIC_IP/32"

# Optional overrides (defaults are fine for most cases)
# aws_region             = "eu-west-1"
# cluster_name           = "network-o11y-demo"
# eks_version            = "1.31"
# eks_node_instance_type = "m5.2xlarge"
# eks_node_desired_count = 2
# eks_node_min_count     = 1
# eks_node_max_count     = 3
