{
  "uid": "net-o11y-traffic-sankey",
  "title": "Network O11y \u2014 Traffic Sankey",
  "description": "Sankey flow diagrams of SR Linux Clos fabric traffic. Uses label_replace() to map gNMI interface names to connected device names.",
  "tags": [
    "network-o11y-demo"
  ],
  "schemaVersion": 41,
  "version": 0,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Spine \u2194 Leaf Traffic",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "netsage-sankey-panel",
      "title": "Spine \u2192 Leaf",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 14,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "linkColor": "multi",
        "nodeColor": "#7EB26D",
        "nodeWidth": 20,
        "nodePadding": 10,
        "layoutIterations": 32
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (source, destination) (  label_replace(    label_replace(      label_replace(        label_replace(          rate(ifHCOutOctets{job=~\"integrations/snmp/spine.*\", ifDescr=~\"ethernet-1/[123]\"}[$__rate_interval]) * 8,          \"source\", \"$1\", \"job\", \"integrations/snmp/(.*)\"        ),        \"destination\", \"leaf1\", \"ifDescr\", \"ethernet-1/1\"      ),      \"destination\", \"leaf2\", \"ifDescr\", \"ethernet-1/2\"    ),    \"destination\", \"leaf3\", \"ifDescr\", \"ethernet-1/3\"  ))",
          "legendFormat": "",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "source": 0,
              "destination": 1,
              "Value": 2
            },
            "renameByName": {
              "source": "Source",
              "destination": "Destination",
              "Value": "bps"
            }
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "netsage-sankey-panel",
      "title": "Leaf \u2192 Spine",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 14,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "linkColor": "multi",
        "nodeColor": "#7EB26D",
        "nodeWidth": 20,
        "nodePadding": 10,
        "layoutIterations": 32
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (source, destination) (  label_replace(    label_replace(      label_replace(        rate(ifHCOutOctets{job=~\"integrations/snmp/leaf.*\", ifDescr=~\"ethernet-1/(49|50)\"}[$__rate_interval]) * 8,        \"source\", \"$1\", \"job\", \"integrations/snmp/(.*)\"      ),      \"destination\", \"spine1\", \"ifDescr\", \"ethernet-1/49\"    ),    \"destination\", \"spine2\", \"ifDescr\", \"ethernet-1/50\"  ))",
          "legendFormat": "",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "source": 0,
              "destination": 1,
              "Value": 2
            },
            "renameByName": {
              "source": "Source",
              "destination": "Destination",
              "Value": "bps"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "netsage-sankey-panel",
      "title": "Spine \u2194 Leaf (Aggregate)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "linkColor": "multi",
        "nodeColor": "#7EB26D",
        "nodeWidth": 20,
        "nodePadding": 10,
        "layoutIterations": 32
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "(sum by (source, destination) (  label_replace(    label_replace(      label_replace(        label_replace(          rate(ifHCOutOctets{job=~\"integrations/snmp/spine.*\", ifDescr=~\"ethernet-1/[123]\"}[$__rate_interval]) * 8,          \"source\", \"$1\", \"job\", \"integrations/snmp/(.*)\"        ),        \"destination\", \"leaf1\", \"ifDescr\", \"ethernet-1/1\"      ),      \"destination\", \"leaf2\", \"ifDescr\", \"ethernet-1/2\"    ),    \"destination\", \"leaf3\", \"ifDescr\", \"ethernet-1/3\"  ))) + on(source, destination) (sum by (source, destination) (  label_replace(    label_replace(      label_replace(        label_replace(          rate(ifHCOutOctets{job=~\"integrations/snmp/leaf.*\", ifDescr=~\"ethernet-1/(49|50)\"}[$__rate_interval]) * 8,          \"source\", \"$1\", \"job\", \"integrations/snmp/(.*)\"        ),        \"destination\", \"$1\", \"source\", \"(leaf.*)\"      ),      \"source\", \"spine1\", \"ifDescr\", \"ethernet-1/49\"    ),    \"source\", \"spine2\", \"ifDescr\", \"ethernet-1/50\"  )))",
          "legendFormat": "",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "source": 0,
              "destination": 1,
              "Value": 2
            },
            "renameByName": {}
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": []
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "fiscalYearStartMonth": 0
}