{
  "uid": "net-o11y-topology",
  "title": "Network O11y \u2014 Network Overview",
  "description": "Live Clos fabric map with fabric-wide health metrics and a full per-device inventory table.",
  "tags": [
    "network-o11y-demo"
  ],
  "schemaVersion": 41,
  "version": 0,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "andrewbmchugh-flow-panel",
      "title": "Fabric Map",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "options": {
        "animationControlEnabled": true,
        "animationsEnabled": true,
        "highlighterEnabled": true,
        "panZoomEnabled": true,
        "timeSliderEnabled": true,
        "testDataEnabled": false,
        "svg": "https://raw.githubusercontent.com/srl-labs/srl-telemetry-lab/refs/heads/flow_panel/configs/grafana/flow_panels/topology.svg",
        "panelConfig": "https://raw.githubusercontent.com/srl-labs/srl-telemetry-lab/refs/heads/flow_panel/configs/grafana/flow_panels/st_topopanel.yml",
        "siteConfig": "https://raw.githubusercontent.com/srl-labs/srl-telemetry-lab/refs/heads/flow_panel/configs/grafana/flow_panels/siteconfig.yml"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "label_replace((2 - ifOperStatus{job=~\"integrations/snmp/(spine|leaf).*\", source!=\"\"}), \"iface_short\", \"e$1-$2\", \"ifDescr\", \"ethernet-(\\\\d+)/(\\\\d+)\")",
          "legendFormat": "oper-state:{{source}}:{{iface_short}}",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "label_replace(rate(ifHCOutOctets{job=~\"integrations/snmp/(spine|leaf).*\", source!=\"\"}[$__rate_interval]) * 8, \"iface_short\", \"e$1-$2\", \"ifDescr\", \"ethernet-(\\\\d+)/(\\\\d+)\")",
          "legendFormat": "{{source}}:{{iface_short}}:out",
          "refId": "B",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "label_replace(rate(ifHCInOctets{job=~\"integrations/snmp/(spine|leaf).*\", source!=\"\"}[$__rate_interval]) * 8, \"iface_short\", \"e$1-$2\", \"ifDescr\", \"ethernet-(\\\\d+)/(\\\\d+)\")",
          "legendFormat": "{{source}}:{{iface_short}}:in",
          "refId": "C",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "BGP Sessions Up",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(avg by (source, neighbor_peer_address) (srl_bgp_neighbor_established_transitions{job=\"integrations/gnmi\"}) >= 1)",
          "legendFormat": "Sessions",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Session Flaps (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(srl_bgp_neighbor_established_transitions{job=\"integrations/gnmi\"}[1h])) or vector(0)",
          "legendFormat": "Flaps",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true
        }
      ]
    },
