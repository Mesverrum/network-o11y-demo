# Grafana Cloud OTLP credentials (Add new connection → OpenTelemetry).
# Copy to .env — never commit the real file.
# Used by Alloy for all telemetry (ktranslate SNMP/flow/syslog + gnmic).
GC_OTLP_URL=https://otlp-gateway-prod-YOUR-REGION.grafana.net/otlp
GC_OTLP_ACCOUNT=000000
GC_OTLP_KEY=glc_REPLACE_ME

# Optional: Grafana HTTP API (service account) for dashboard import scripts.
# GRAFANA_URL=https://yourstack.grafana.net
# GRAFANA_TOKEN=glsa_REPLACE_ME
# Optional (Windows): gcx path + context for scripts/import-network-join-demo-gcx.py
# GCX_BIN=C:/path/to/gcx.exe
# GCX_CONTEXT=yourstack

# Identifies this ktranslate host. Alloy stamps it as deployment_host on every
# signal; it also suffixes service.name (e.g. ktranslate-snmp-srl-<host>).
# Leave blank so `make` uses the machine hostname.
KTRANS_HOST=

# Topology / entity graph label (Prometheus tester_id). Defaults to KTRANS_HOST
# or hostname when blank. Set explicitly for a stable id across machines.
LAB_TESTER_ID=network-lab

# Container image pins (leave blank for :latest)
KTRANSLATE_IMAGE=
ALLOY_IMAGE=
GNMIC_IMAGE=
TOPOLOGY_EXPORTER_IMAGE=

# SNMP community for topology-exporter (matches groups/srl.env)
SNMP_COMMUNITY=public

OTEL_SERVICE_NAME=ktranslate
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
# softflowd on clients emits NetFlow v9
NF_SOURCE=netflow9
SYSLOG_SOURCE=0.0.0.0:1514

# Per-container memory limits (scripts/compute-limits.sh on make up)
# MEM_LIMITS=off
# MEM_BUDGET_FRACTION=0.80
# MEM_SNMP_MAX=4g

# NetBox — only if a group sets DISCOVERY_SOURCE=netbox (not used by default)
NETBOX_HOST=
NETBOX_TOKEN=

# ContainerLab management Docker network (clab 0.72+ uses the shared "clab" bridge)
CLAB_NETWORK=clab
