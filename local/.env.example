# Grafana Cloud OTLP credentials (Add new connection → OpenTelemetry).
# Copy to .env — never commit the real file.
# Used by Alloy for all telemetry (ktranslate SNMP/flow/syslog + gnmic).
GC_OTLP_URL=https://otlp-gateway-prod-YOUR-REGION.grafana.net/otlp
GC_OTLP_ACCOUNT=000000
GC_OTLP_KEY=glc_REPLACE_ME

# Grafana HTTP API — used by the one-click scripts (oneclick/) to import the
# network-lab dashboards with a token (no OAuth). Create the token at:
#   Grafana → Administration → Users and access → Service accounts → Add token (Editor/Admin)
# GRAFANA_URL=https://yourstack.grafana.net
# GRAFANA_TOKEN=glsa_REPLACE_ME
#
# Grafana Cloud Access Policy token with the `stack-plugins:write` scope — lets the
# one-click scripts install the panel plugins (andrewbmchugh-flow-panel,
# netsage-sankey-panel) via the grafana.com Cloud API. Create at:
#   Grafana Cloud portal → Access Policies → new policy (scope: stack-plugins:write) → Add token
# (Or add the stack-plugins:write scope to your OTLP access policy and reuse GC_OTLP_KEY.)
# GC_STACK_TOKEN=glc_REPLACE_ME
# Optional (Windows): gcx path + context for scripts/import-network-join-demo-gcx.py
# GCX_BIN=C:/path/to/gcx.exe
# GCX_CONTEXT=yourstack

# Identifies this ktranslate host. Alloy stamps it as deployment_host on every
# signal; it also suffixes service.name (e.g. ktranslate-snmp-srl-<host>).
# Leave blank so `make` uses the machine hostname.
KTRANS_HOST=

# Topology / entity graph label (Prometheus tester_id). Defaults to KTRANS_HOST
# or hostname when blank. Set explicitly for a stable id across machines.
LAB_TESTER_ID=network-lab

# Container image pins (leave blank for :latest)
KTRANSLATE_IMAGE=
ALLOY_IMAGE=
GNMIC_IMAGE=
TOPOLOGY_EXPORTER_IMAGE=

# SNMP community for topology-exporter (matches groups/srl.env)
SNMP_COMMUNITY=public

# Optional — Telegraf flex PoC SSH (make telegraf-poc); ContainerLab SR Linux defaults
# SRL_SSH_USER=admin
# SRL_SSH_PASSWORD=NokiaSrl1!

OTEL_SERVICE_NAME=ktranslate
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
# softflowd on clients emits NetFlow v9
NF_SOURCE=netflow9
SYSLOG_SOURCE=0.0.0.0:1514

# Per-container memory limits (scripts/compute-limits.sh on make up)
# Uses /proc/meminfo on Linux, docker info on Docker Desktop (Mac/Windows), or sysctl on macOS.
# MEM_LIMITS=off
# MEM_BUDGET_FRACTION=0.80
# MEM_SNMP_MAX=4g

# Optional — NetBox Cloud (only when DISCOVERY_SOURCE=netbox in groups/*.env)
# Copy groups/srl.env.netbox.sample → groups/srl.env and uncomment below.
# Token: NetBox UI → profile → API Tokens (write enabled for populate scripts)
# NETBOX_URL=https://YOUR-TENANT.cloud.netboxapp.com
# NETBOX_HOST_URL=https://YOUR-TENANT.cloud.netboxapp.com
# NETBOX_API_URL=https://YOUR-TENANT.cloud.netboxapp.com/api/dcim/devices/
# NETBOX_TOKEN=nbt_REPLACE_ME

# ContainerLab management Docker network (clab 0.72+ uses the shared "clab" bridge)
CLAB_NETWORK=clab

# Staggered bring-up (default on): pause between fabric nodes and collectors.
# Reduces simultaneous SR Linux boot + compose pull load on resource-constrained laptops.
# LAB_STAGGER=0           parallel bring-up (make up-parallel)
# LAB_STAGGER_SECS=25     seconds between each component (default)
# LAB_STAGGER_FABRIC=0    skip fabric node stagger (collectors still stagger)
# LAB_STAGGER_COLLECTORS=0  compose up -d all collectors at once

# WSL /mnt/c: fabric deploy mirrors to native ext4 (startup-config + clab labdir).
# Default: ~/.cache/network-o11y-demo/clab — override if you prefer another path.
# CLAB_EXT4_ROOT=/home/you/projects/network-o11y-demo/local
# CLAB_FORCE_EXT4=1
