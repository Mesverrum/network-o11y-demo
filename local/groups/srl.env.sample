# Clos fabric SNMP group (spine1, leaf1, leaf2) — KtransToGrafana golden path.
# Copy to groups/srl.env (without .sample).
#
#   cp groups/srl.env.sample groups/srl.env
#   make generate && make up && make discover GROUP=srl
#
# Default: CIDR discovery — `make up` rewrites TARGETS from live clab mgmt /32s.
# Optional NetBox Cloud: copy groups/srl.env.netbox.sample instead (see local/netbox/README.md).

GROUP=srl

SNMP_VERSION=v2c
SNMP_V2_COMMUNITY=public
TRAP_COMMUNITY=public

DISCOVERY_SOURCE=cidr
# Placeholder — `make up` / scripts/update-snmp-targets.sh replace with clab /32s.
TARGETS=172.20.20.0/24

METALISTEN_PORT=9997
TRAP_PORT=1620

DISCOVERY_THREADS=4
POLL_INTERVAL_SEC=60
