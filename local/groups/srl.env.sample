# Clos fabric SNMP group (spine1, leaf1, leaf2) — KtransToGrafana golden path.
# Copy to groups/srl.env (without .sample). `make snmp-targets` rewrites TARGETS
# from live ContainerLab mgmt /32s after deploy.
#
#   make generate && make up && make discover GROUP=srl

GROUP=srl

SNMP_VERSION=v2c
SNMP_V2_COMMUNITY=public
TRAP_COMMUNITY=public

DISCOVERY_SOURCE=cidr
# Placeholders — scripts/update-snmp-targets.sh replaces with clab /32s.
TARGETS=172.20.20.0/24

METALISTEN_PORT=9997
TRAP_PORT=1620

DISCOVERY_THREADS=4
POLL_INTERVAL_SEC=60
