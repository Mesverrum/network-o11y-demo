# Optional: NetBox Cloud inventory-driven SNMP discovery.
# Copy to groups/srl.env and set NETBOX_* in .env (see local/netbox/README.md).
#
#   cp groups/srl.env.netbox.sample groups/srl.env
#   # edit .env with your NetBox Cloud URL + API token
#   make generate && make netbox-sync && make up

GROUP=srl

SNMP_VERSION=v2c
SNMP_V2_COMMUNITY=public
TRAP_COMMUNITY=public

DISCOVERY_SOURCE=netbox
NETBOX_SITE=network-lab
NETBOX_ROLE=spine,leaf
NETBOX_IP_TO_PICK=primary_ip4

# Unused when DISCOVERY_SOURCE=netbox (kept for switching back to cidr).
TARGETS=172.20.20.0/24

METALISTEN_PORT=9997
TRAP_PORT=1620

DISCOVERY_THREADS=4
POLL_INTERVAL_SEC=60
