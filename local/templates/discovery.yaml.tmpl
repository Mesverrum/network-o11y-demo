# GENERATED by scripts/generate-groups.sh from groups/${GROUP}.env — do not edit by hand.
# The device list comes from this group's DISCOVERY_SOURCE: a cidr scan fills
# `cidrs:`, while netbox leaves it empty and adds a `netbox:` block below whose
# ${NETBOX_API_URL}/${NETBOX_TOKEN} are resolved by ktranslate from the discover
# container's env at runtime (url is baked at `make generate` from .env).
devices: {}
trap:
    listen: 0.0.0.0:${TRAP_PORT}
    community: ${TRAP_COMMUNITY}
    version: ""
    transport: ""
    v3_config: null
    trap_only: false
    drop_undefined: false
    endpoint: ""
    endpoint_port: 0
discovery:
    cidrs:${CIDRS_YAML}
    ignore_list: []
    debug: false
    ports:
      - 161
    default_communities:${DEFAULT_COMMUNITIES_YAML}
    use_snmp_v1: false
    default_v3:${DEFAULT_V3_YAML}${OTHER_V3S_YAML}
    add_devices: true
    add_mibs: true
    threads: ${DISCOVERY_THREADS}
    replace_devices: true
    kentik: null
    no_use_bulkwalkall: false${NETBOX_BLOCK_YAML}
global:
    poll_time_sec: ${POLL_INTERVAL_SEC}
    drop_if_outside_poll: false
    mib_profile_dir: /etc/ktranslate/profiles
    mibs_db: ""
    mibs_enabled:
      - IF-MIB
      - TIMETRA-SYSTEM-MIB
      - TIMETRA-CHASSIS-MIB
      - TIMETRA-BGP-MIB
    timeout_ms: 10000
    retries: 1
    global_v3: null
    response_time: true
    purge_devices_after_num: 0
    no_device_hardcoded_oids: false
    user_tags: {}
    match_attributes: {}
    providers: {}
    jitter_time_sec: 30
    fast_poll: false
    watch_profile_changes: false
    save_mds_cache: false
