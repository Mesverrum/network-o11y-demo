        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(kentik_snmp_Uptime{device_name=~\"$device\"} / 100)",
          "legendFormat": "Uptime",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true
        }
      ]
    },
    {
