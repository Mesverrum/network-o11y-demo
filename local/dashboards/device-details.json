        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "group by (device_name, model) (label_replace(kentik_snmp_Uptime{device_name=~\"$device\"}, \"model\", \"$1\", \"kentik_snmp_Uptime\", \"SRLinux-[^ ]+ (7220 IXR-[A-Z0-9]+).*\"))",
          "legendFormat": "{{model}}",
          "refId": "A",
          "editorMode": "code",
          "range": false,
          "instant": true
        }
