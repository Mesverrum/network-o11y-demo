          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(kentik_snmp_ifHCInOctets{}, device_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {},
        "hide": 0,
        "options": [],
        "allValue": ".*"
      },
