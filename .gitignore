# AWS credentials — never commit
aws.credentials
*.pem
*.pem.pub

# Local environment overrides
.env
.env.out
values.local.yaml

# Local lab secrets / mutable ktranslate discovery state
local/.env
local/groups/*.env
!local/groups/*.env.sample
!local/groups/*.env.*.sample
local/config/
local/state/
local/compose-groups.generated.yaml
local/compose-limits.generated.yaml
local/snmp.yaml
local/.dash-payloads/
local/.ref-KtransToGrafana/
local/clab-srl-local/

# Terraform state and working files
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfvars
*.tfplan
tfplan

# Generated SSH keys
network-o11y-demo.pem

# Grafana Cloud credentials (copy from .example, fill in, never commit)
k8s/telemetry/grafana-cloud-secret.yaml

# NetBox credentials (copy from .example, fill in, never commit)
k8s/netbox/netbox-secret.yaml

# Grafana Cloud API token and instance details — never commit
grafana-cloud-api.token
grafana-cloud.instance

# Python cache
__pycache__/
*.pyc

# Ansible config backups — these are generated at runtime, not source-controlled here.
# In a real deployment, commit backups/ to a dedicated private repo for audit history.
ansible/backups/

# Ansible retry files
ansible/*.retry
ansible/playbooks/*.retry

# Local lab built binaries
local/join-app/join-app

# Agent/debug scratch scripts (underscore prefix) and one-off personal imports
local/scripts/_*
local/scripts/import-netterfield-wip.py
local/scripts/preserve-ktranslate-uids.py
local/scripts/retarget-otlp-networko11ydev.py

# OS noise
.DS_Store
.DS_Store?
*.docx
